# Environment template - do not commit real secrets

# Supabase project for the NEW independent subscription site
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_ONLY_FOR_EDGE_FUNCTIONS_OR_CLI

# Patreon OAuth - only needed if Patreon is enabled
PATREON_CLIENT_ID=YOUR_PATREON_CLIENT_ID
PATREON_CLIENT_SECRET=YOUR_PATREON_CLIENT_SECRET
PATREON_REDIRECT_URI=https://YOUR_PROJECT_REF.supabase.co/functions/v1/patreon-oauth-callback
PATREON_STATE_SECRET=GENERATE_LONG_RANDOM_SECRET
PATREON_CAMPAIGN_ID=OPTIONAL_CAMPAIGN_ID
PATREON_USER_AGENT=Your Site Name / contact@example.com

# Optional webhook boundary
PROVIDER_WEBHOOK_SECRET=GENERATE_LONG_RANDOM_SECRET
